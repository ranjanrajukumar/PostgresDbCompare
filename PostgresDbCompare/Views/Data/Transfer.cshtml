@model List<string>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="container mt-4">

    <h3 class="mb-4 text-primary">Transfer Table Data</h3>

    <form id="transferForm" asp-action="TransferData" method="post">

        @Html.AntiForgeryToken()

        <div class="row g-3">

            @foreach (var table in Model)
            {
                <div class="col-md-4">

                    <div class="card shadow-sm">

                        <div class="card-body">

                            <input type="checkbox"
                                   name="selectedTables"
                                   value="@table"
                                   checked />

                            <span class="ms-2">@table</span>

                        </div>

                    </div>

                </div>
            }

        </div>

        <div class="text-center mt-4">

            <button id="transferBtn" class="btn btn-success btn-lg">
                Transfer Selected Tables
            </button>

        </div>

    </form>

</div>


<!-- Loader Modal -->
<div class="modal fade" id="loaderModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content text-center p-4">

            <div class="spinner-border text-primary" style="width:4rem;height:4rem"></div>

            <h5 class="mt-3">Transferring Data...</h5>
            <p>Please wait</p>

        </div>
    </div>
</div>


<script>

    document.getElementById("transferForm").addEventListener("submit", function () {

        var modal = new bootstrap.Modal(document.getElementById('loaderModal'));
        modal.show();

    });


</script>


@if (TempData["msg"] != null)
{
    <script>
        Swal.fire({
        icon:'success',
        title:'Success',
        text:'@TempData["msg"]'
        });
    </script>
}

@if (TempData["error"] != null)
{
    <script>
        Swal.fire({
        icon:'error',
        title:'Error',
        text:'@TempData["error"]'
        });
    </script>
}