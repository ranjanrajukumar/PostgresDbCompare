@model List<string>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="container mt-4">

    <h3 class="mb-4 text-primary">Transfer Table Data</h3>

    <form asp-action="TransferData" method="post">

        <div class="row g-3">

            @foreach (var table in Model)
            {
                <div class="col-md-4">

                    <div class="card shadow-sm">

                        <div class="card-body">

                            <input type="checkbox"
                                   name="selectedTables"
                                   value="@table"
                                   checked />

                            <span class="ms-2">@table</span>

                        </div>

                    </div>

                </div>
            }

        </div>

        <div class="text-center mt-4">

            <button class="btn btn-success btn-lg">
                Transfer Selected Tables
            </button>

        </div>

    </form>

</div>