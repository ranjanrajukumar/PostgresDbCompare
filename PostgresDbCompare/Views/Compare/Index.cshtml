@model PostgresDbCompare.Models.DbConnectionModel

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="container mt-5">

    <div class="text-center mb-4">
        <h2 class="fw-bold text-primary">PostgreSQL Database Compare Tool</h2>
        <p class="text-muted">Compare Tables, Columns, Views, Functions, Indexes & Data</p>
    </div>

    <!-- SUCCESS MESSAGE -->
    @if (TempData["msg"] != null)
    {
        <script>
            Swal.fire({
                icon: 'success',
                title: 'Success',
                text: '@TempData["msg"]'
            });
        </script>
    }

    <!-- ERROR MESSAGE -->
    @if (TempData["error"] != null)
    {
        <script>
            Swal.fire({
                icon: 'error',
                title: 'Error',
                text: '@TempData["error"]'
            });
        </script>
    }

    <form asp-controller="Compare" asp-action="Compare" method="post">
        @Html.AntiForgeryToken()

        <div class="row g-4">

            <!-- SOURCE DATABASE -->
            <div class="col-md-6">
                <div class="card shadow border-0">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">Source Database</h5>
                    </div>

                    <div class="card-body">

                        <div class="mb-3">
                            <label class="form-label">Host</label>
                            <input asp-for="SourceHost" class="form-control" value="localhost" required />
                            <span asp-validation-for="SourceHost" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Port</label>
                            <input asp-for="SourcePort" type="number" class="form-control" value="5432" required />
                            <span asp-validation-for="SourcePort" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Database</label>
                            <input asp-for="SourceDatabase" class="form-control" required />
                            <span asp-validation-for="SourceDatabase" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Username</label>
                            <input asp-for="SourceUsername" class="form-control" value="postgres" required />
                            <span asp-validation-for="SourceUsername" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Password</label>
                            <input asp-for="SourcePassword" type="password" class="form-control" />
                            <span asp-validation-for="SourcePassword" class="text-danger"></span>
                        </div>

                    </div>
                </div>
            </div>


            <!-- TARGET DATABASE -->
            <div class="col-md-6">
                <div class="card shadow border-0">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0">Target Database</h5>
                    </div>

                    <div class="card-body">

                        <div class="mb-3">
                            <label class="form-label">Host</label>
                            <input asp-for="TargetHost" class="form-control" value="localhost" required />
                            <span asp-validation-for="TargetHost" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Port</label>
                            <input asp-for="TargetPort" type="number" class="form-control" value="5432" required />
                            <span asp-validation-for="TargetPort" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Database</label>
                            <input asp-for="TargetDatabase" class="form-control" required />
                            <span asp-validation-for="TargetDatabase" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Username</label>
                            <input asp-for="TargetUsername" class="form-control" value="postgres" required />
                            <span asp-validation-for="TargetUsername" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Password</label>
                            <input asp-for="TargetPassword" type="password" class="form-control" />
                            <span asp-validation-for="TargetPassword" class="text-danger"></span>
                        </div>

                    </div>
                </div>
            </div>

        </div>

        <div class="text-center mt-4">
            <button type="submit" class="btn btn-lg btn-primary px-5 shadow">
                🔍 Compare Databases
            </button>
        </div>

    </form>

</div>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}