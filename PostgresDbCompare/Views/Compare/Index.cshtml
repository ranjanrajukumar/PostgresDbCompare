@model PostgresDbCompare.Models.DbConnectionModel

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="container mt-5">

    <div class="text-center mb-4">
        <h2 class="fw-bold text-primary">PostgreSQL Database Compare Tool</h2>
        <p class="text-muted">Compare Tables, Columns, Views, Functions, Indexes & Data</p>
    </div>

    <form asp-controller="Compare" asp-action="Compare" method="post">
        @Html.AntiForgeryToken()

        <div class="row g-4">

            <!-- Source Database -->
            <div class="col-md-6">
                <div class="card shadow border-0">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">Source Database</h5>
                    </div>

                    <div class="card-body">

                        <div class="mb-3">
                            <label class="form-label">Host</label>
                            <input asp-for="SourceHost" class="form-control" value="localhost" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Port</label>
                            <input asp-for="SourcePort" class="form-control" value="5432" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Database</label>
                            <input asp-for="SourceDatabase" class="form-control" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Username</label>
                            <input asp-for="SourceUsername" class="form-control" value="postgres" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Password</label>
                            <input asp-for="SourcePassword" type="password" class="form-control" />
                        </div>

                    </div>
                </div>
            </div>


            <!-- Target Database -->
            <div class="col-md-6">
                <div class="card shadow border-0">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0">Target Database</h5>
                    </div>

                    <div class="card-body">

                        <div class="mb-3">
                            <label class="form-label">Host</label>
                            <input asp-for="TargetHost" class="form-control" value="localhost" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Port</label>
                            <input asp-for="TargetPort" class="form-control" value="5432" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Database</label>
                            <input asp-for="TargetDatabase" class="form-control" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Username</label>
                            <input asp-for="TargetUsername" class="form-control" value="postgres" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Password</label>
                            <input asp-for="TargetPassword" type="password" class="form-control" />
                        </div>

                    </div>
                </div>
            </div>

        </div>

        <div class="text-center mt-4">
            <button type="submit" class="btn btn-lg btn-primary px-5">
                🔍 Compare Databases
            </button>
        </div>

    </form>

</div>