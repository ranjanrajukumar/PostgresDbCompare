@model PostgresDbCompare.Models.CompareResultModel

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="container mt-4">

    <h2 class="text-center text-primary mb-4">
        Database Compare Result
    </h2>

    <div class="row g-4">

        <!-- Missing Tables -->
        <div class="col-md-4">
            <div class="card shadow border-0">
                <div class="card-header bg-primary text-white">
                    Missing Tables (@Model.MissingTables.Count)
                </div>
                <ul class="list-group list-group-flush">
                    @if (Model.MissingTables.Any())
                    {
                        foreach (var item in Model.MissingTables)
                        {
                            <li class="list-group-item">@item</li>
                        }
                    }
                    else
                    {
                        <li class="list-group-item text-success">
                            No Missing Tables
                        </li>
                    }
                </ul>
            </div>
        </div>


        <!-- Missing Columns -->
        <div class="col-md-4">
            <div class="card shadow border-0">
                <div class="card-header bg-secondary text-white">
                    Missing Columns (@Model.MissingColumns.Count)
                </div>
                <ul class="list-group list-group-flush">
                    @if (Model.MissingColumns.Any())
                    {
                        foreach (var item in Model.MissingColumns)
                        {
                            <li class="list-group-item">@item</li>
                        }
                    }
                    else
                    {
                        <li class="list-group-item text-success">
                            No Missing Columns
                        </li>
                    }
                </ul>
            </div>
        </div>


        <!-- Missing Views -->
        <div class="col-md-4">
            <div class="card shadow border-0">
                <div class="card-header bg-warning">
                    Missing Views (@Model.MissingViews.Count)
                </div>
                <ul class="list-group list-group-flush">
                    @if (Model.MissingViews.Any())
                    {
                        foreach (var item in Model.MissingViews)
                        {
                            <li class="list-group-item">@item</li>
                        }
                    }
                    else
                    {
                        <li class="list-group-item text-success">
                            No Missing Views
                        </li>
                    }
                </ul>
            </div>
        </div>


        <!-- Missing Functions -->
        <div class="col-md-4">
            <div class="card shadow border-0">
                <div class="card-header bg-danger text-white">
                    Missing Functions (@Model.MissingFunctions.Count)
                </div>
                <ul class="list-group list-group-flush">
                    @if (Model.MissingFunctions.Any())
                    {
                        foreach (var item in Model.MissingFunctions)
                        {
                            <li class="list-group-item">@item</li>
                        }
                    }
                    else
                    {
                        <li class="list-group-item text-success">
                            No Missing Functions
                        </li>
                    }
                </ul>
            </div>
        </div>


        <!-- Missing Indexes -->
        <div class="col-md-4">
            <div class="card shadow border-0">
                <div class="card-header bg-info text-white">
                    Missing Indexes (@Model.MissingIndexes.Count)
                </div>
                <ul class="list-group list-group-flush">
                    @if (Model.MissingIndexes.Any())
                    {
                        foreach (var item in Model.MissingIndexes)
                        {
                            <li class="list-group-item">@item</li>
                        }
                    }
                    else
                    {
                        <li class="list-group-item text-success">
                            No Missing Indexes
                        </li>
                    }
                </ul>
            </div>
        </div>


        <!-- Missing Constraints -->
        <div class="col-md-4">
            <div class="card shadow border-0">
                <div class="card-header bg-dark text-white">
                    Missing Constraints (@Model.MissingConstraints.Count)
                </div>
                <ul class="list-group list-group-flush">
                    @if (Model.MissingConstraints.Any())
                    {
                        foreach (var item in Model.MissingConstraints)
                        {
                            <li class="list-group-item">@item</li>
                        }
                    }
                    else
                    {
                        <li class="list-group-item text-success">
                            No Missing Constraints
                        </li>
                    }
                </ul>
            </div>
        </div>

    </div>


    <!-- Generated SQL Script -->
    <div class="mt-5">

        <h4 class="text-primary">
            Generated Migration Script
        </h4>

        <textarea class="form-control" rows="10" readonly>
@Model.GeneratedScript
        </textarea>

    </div>


    <!-- Transfer Button -->
    <div class="text-center mt-4">

        <form asp-controller="Compare" asp-action="TransferObjects" method="post">

            @Html.AntiForgeryToken()

            <!-- Send Script -->
            <input type="hidden"
                   name="script"
                   value="@Model.GeneratedScript" />

            <!-- Send Target Connection -->
            <input type="hidden"
                   name="connection"
                   value="@ViewBag.TargetConnection" />

            <button type="submit"
                    class="btn btn-success btn-lg px-5">

                🚀 Transfer Missing Objects

            </button>

        </form>


        <a asp-controller="Compare"
           asp-action="Index"
           class="btn btn-secondary btn-lg ms-3">

            Back

        </a>

    </div>

</div>